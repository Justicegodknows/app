#!/bin/sh
commit_msg=$(cat "$1")

# Skip merge commits, fixup, squash, etc.
case "$commit_msg" in
  Merge\ *|Revert\ *|fixup\!*|squash\!*) exit 0 ;;
esac

pattern='^#[0-9]+ \([a-z]+\): .+'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  Invalid commit message format."
  echo "  Expected: {ticket_id} ({type}): {description}"
  echo "  Example:  #123 (feat): add user login"
  echo "  Types:    feat, fix, ref, refactor, chore, docs, test, style, perf, ci"
  echo ""
  exit 1
fi
